# Recommended [Service] settings for a bot process.
#
# ExecStopPost is used instead of OnFailure because Restart=always can restart
# the service before the unit stays in failed state.
#
# ExecStopPost=%h/sklad/env/bin/python %h/sklad/scripts/systemd_failure_alert.py %n
# Restart=always
# RestartSec=5
# StartLimitBurst=5
# StartLimitIntervalSec=300
